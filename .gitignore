__pycache__/
*.pyc
.venv/
.env
*.egg-info/
.ruff_cache/
logs/*.log
logs/*.lock

# Não versionar uv.lock: o builder Python do Vercel, ao detectar esse arquivo,
# instala nosso próprio pacote (via uv) como editável, registrando um pacote
# "api" que colide com a pasta api/ exigida pelo Vercel para a função serverless.
uv.lock
