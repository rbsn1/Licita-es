# Connection string do Supabase (Project Settings > Database > Connection string > URI,
# modo "Transaction pooler" recomendado para app; troque postgresql:// por postgresql+psycopg://)
DATABASE_URL=postgresql+psycopg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
PNCP_BASE_URL=https://pncp.gov.br/api/consulta

# Resend (https://resend.com) — usado para o alerta por e-mail (RF-03)
RESEND_API_KEY=re_xxxxxxxx
# Sem domínio verificado no Resend, use o remetente sandbox abaixo — só envia
# para o e-mail associado à sua conta Resend
RESEND_FROM_EMAIL=onboarding@resend.dev

# URL pública onde o dashboard está hospedado — usada para montar o link
# "/dashboard/{token}" no e-mail de alerta (RF-03).
# ATENÇÃO: nas env vars do projeto na Vercel, isso PRECISA ser o domínio real de
# produção (ex: https://seu-projeto.vercel.app) — se ficar http://localhost:8000
# lá, todo e-mail de alerta em produção sai com link quebrado.
DASHBOARD_BASE_URL=http://localhost:8000

# E-mail do operador da consultoria (você) — recebe alerta se a varredura do cron falhar
OPERADOR_EMAIL=seu-email@dominio.com

# Segredo do endpoint /cron/prospectar (RNF-01). Gere um valor aleatório e cadastre
# com o MESMO nome (CRON_SECRET) nas env vars do projeto na Vercel — a Vercel injeta
# automaticamente "Authorization: Bearer $CRON_SECRET" nas chamadas do Cron Job.
# Sem essa variável configurada, o endpoint recusa todas as requisições.
CRON_SECRET=
